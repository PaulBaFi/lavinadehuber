---
const {
  size = "24",
  classStyles = "group-hover:translate-x-1 transition-transform",
  strokeWidth = "1.5",
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  class={classStyles}
  fill="none"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  stroke="currentColor"
>
  <path
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width={strokeWidth}
    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
</svg>
