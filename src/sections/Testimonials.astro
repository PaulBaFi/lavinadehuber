---
import TestimonialCard from "@/components/TestimonialCard.astro";
import Star from "@/icons/Star.astro";
import { reseñas } from "@/lib/data";
---

<section class="py-32 bg-white relative overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none select-none overflow-hidden opacity-[0.03] reveal"
  >
    <p class="text-[30rem] font-title absolute -top-40 -left-20 italic">“</p>
    <p class="text-[30rem] font-title absolute -bottom-40 -right-20 italic">
      ”
    </p>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-3xl mb-24 reveal">
      <span
        class="text-brands-primary font-bold tracking-[0.5em] uppercase text-[10px] mb-4 block"
      >
        Testimonios
      </span>
      <h2
        class="text-4xl md:text-6xl font-title font-bold text-ink-primary leading-none"
      >
        Sensaciones
        <span class="text-brands-primary italic">reales.</span>
      </h2>
    </div>

    <div
      class="columns-1 md:columns-2 lg:columns-3 gap-6 md:gap-12 space-y-6 md:space-y-12"
    >
      {reseñas.map((r, index) => <TestimonialCard item={r} index={index} />)}
    </div>
  </div>
</section>
