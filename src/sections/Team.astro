---
import { equipo } from "@/lib/data";
import TeamCard from "@/components/TeamCard.astro";
---

<section class="py-12 md:py-24 bg-surface-dark text-white overflow-hidden">
  <div class="container mx-auto px-4">
    <div
      class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6 reveal"
    >
      <div class="max-w-2xl">
        <span
          class="text-brands-primary font-bold tracking-[0.3em] uppercase text-xs mb-4 block"
        >
          EL EQUIPO
        </span>
        <h2
          class="text-5xl md:text-7xl font-title font-bold italic leading-tight"
        >
          Nuestra <span class="text-brands-primary">Familia</span>
        </h2>
      </div>
      <div class="hidden md:block w-32 h-px bg-white/20 mb-4"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        equipo.map((persona, index) => (
          <TeamCard persona={persona} index={index} />
        ))
      }
    </div>
  </div>
</section>
