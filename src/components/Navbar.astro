---
import Location from "@/icons/Location.astro";
import Phone from "@/icons/Phone.astro";
import { contacto } from "@/lib/data";

const wsp = contacto.whatsapp;

const navLinks = [
  { name: "Inicio", href: "/" },
  { name: "La Carta", href: "/carta" },
  { name: "Nosotros", href: "/nosotros" },
  { name: "Reservar", href: "/reservar" },
];
---

<nav
  class="fixed w-full z-50 transition-all duration-500 ease-in-out"
  id="main-nav"
>
  <div
    id="top-bar"
    class="bg-black/30 border-b border-white/10 py-2 transition-all duration-500 hidden md:block"
  >
    <div
      class="container mx-auto px-4 flex justify-between items-center text-[10px] font-body tracking-widest text-white/80"
    >
      <div class="flex items-center gap-6">
        <a
          href={`mailto:${contacto.address}`}
          target="_blank"
          class="flex items-center gap-1.5 uppercase"
        >
          <Location size="13" strokeWidth="2" />
          {contacto.address}
        </a>
        <a
          href={`https://wa.me/${wsp}`}
          target="_blank"
          class="flex items-center gap-1.5 uppercase"
        >
          <Phone size="13" strokeWidth="2" />
          {contacto.phone}
        </a>
      </div>
      <div class="flex gap-4 uppercase">
        <a
          href={contacto.social.instagram}
          target="_blank"
          class="hover:text-brands-primary transition-colors">Instagram</a
        >
        <a
          href={contacto.social.facebook}
          target="_blank"
          class="hover:text-brands-primary transition-colors">Facebook</a
        >
      </div>
    </div>
  </div>

  <div id="nav-content" class="py-4 transition-all duration-500 relative z-60">
    <div class="container mx-auto px-4 flex justify-between items-center">
      <a
        href="/"
        class="text-2xl font-bold tracking-tighter font-title"
        id="nav-logo"
      >
        <span class="text-brands-primary">LA VIÑA </span><span
          class="text-white uppercase font-light tracking-widest">de Húber</span
        >
      </a>

      <div class="hidden md:flex gap-8 items-center">
        {
          navLinks
            .filter((l) => l.name !== "Reservar")
            .map((link) => (
              <a
                href={link.href}
                class="font-medium text-white/90 hover:text-brands-primary transition-colors font-body text-sm uppercase tracking-[0.2em] border-b border-transparent hover:border-brands-primary/50"
              >
                {link.name}
              </a>
            ))
        }
        <a
          href="/reservar"
          class="bg-brands-primary text-black px-6 py-2.5 rounded-full font-bold hover:bg-white transition-all transform hover:scale-105 font-title shadow-lg"
        >
          Reservar
        </a>

        <button
          id="cart-toggle"
          class="relative p-3 text-white hover:text-brands-primary transition-all duration-300 group focus:outline-none"
        >
          <span
            id="cart-pulse"
            class="absolute inset-0 m-auto w-10 h-10 rounded-full bg-brands-primary/40 opacity-0 pointer-events-none hidden"
          ></span>
          <svg
            class="relative z-10"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"
            ></circle>
            <path
              d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"
            ></path>
          </svg>
          <span
            id="cart-count"
            class="absolute top-1 right-1 bg-brands-primary text-black text-[9px] font-bold w-5 h-5 rounded-full flex items-center justify-center opacity-0 transition-all z-20 shadow-sm border-2 border-white"
            >0</span
          >
        </button>
      </div>

      <div class="flex items-center gap-2 md:hidden">
        <button id="cart-toggle-mobile" class="p-2 text-white">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"
            ></circle><path
              d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"
            ></path></svg
          >
        </button>
        <button id="menu-open" class="text-white p-2 md:hidden relative z-50">
          <svg
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 bg-surface-dark w-full h-screen z-100 flex flex-col justify-center items-center text-center translate-x-full transition-transform duration-500 ease-in-out md:hidden"
  >
    <button
      id="menu-close"
      class="absolute top-6 right-6 text-white p-2 hover:rotate-90 transition-transform duration-300"
    >
      <svg
        width="32"
        height="32"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div class="flex flex-col space-y-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="block text-4xl font-bold text-white hover:text-brands-primary font-title italic tracking-tighter mobile-link opacity-0"
          >
            {link.name}
          </a>
        ))
      }
    </div>

    <div
      class="absolute bottom-12 w-full px-6 text-center space-y-4 opacity-0 transition-opacity duration-700 delay-300"
      id="mobile-footer"
    >
      <div class="h-px bg-white/10 w-24 mx-auto mb-6"></div>
      <div class="flex flex-col gap-4">
        <a
          href={contacto.google_maps}
          target="_blank"
          class="text-white/60 text-xs tracking-widest"
        >
          {contacto.address}
        </a>
        <a
          href={`https://wa.me/${wsp}`}
          target="_blank"
          class="text-brands-primary font-bold">{contacto.phone}</a
        >
      </div>
      <div
        class="flex justify-center gap-6 pt-4 text-[10px] text-white/40 tracking-[0.3em]"
      >
        <a target="_blank" href={contacto.social.instagram}>INSTAGRAM</a>
        <a target="_blank" href={contacto.social.facebook}>FACEBOOK</a>
      </div>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById("main-nav");
  const topBar = document.getElementById("top-bar");
  const navContent = document.getElementById("nav-content");

  const openBtn = document.getElementById("menu-open");
  const closeBtn = document.getElementById("menu-close");
  const menu = document.getElementById("mobile-menu");
  const mobileFooter = document.getElementById("mobile-footer");

  // Detectar si es Desktop (Tailwind md = 768px)
  const isDesktop = () => window.innerWidth >= 768;

  // --- LÓGICA DE SCROLL ---
  window.addEventListener("scroll", () => {
    const isMenuOpen = !menu?.classList.contains("translate-x-full");

    if (window.scrollY > 40) {
      nav?.classList.add("bg-surface-dark/95", "backdrop-blur-md", "shadow-lg");
      navContent?.classList.replace("py-4", "py-2");

      // En scroll siempre ocultamos el topBar (si existe y es desktop)
      if (isDesktop()) {
        topBar?.classList.add("hidden");
      }
    } else {
      // VOLVER AL TOP
      if (!isMenuOpen) {
        nav?.classList.remove(
          "bg-surface-dark/95",
          "backdrop-blur-md",
          "shadow-lg",
        );
        navContent?.classList.replace("py-2", "py-4");

        // SOLO mostramos el topBar si estamos en Desktop
        if (isDesktop()) {
          topBar?.classList.remove("hidden");
        }
      }
    }
  });

  // --- FUNCIÓN ABRIR ---
  openBtn?.addEventListener("click", () => {
    menu?.classList.remove("translate-x-full");
    mobileFooter?.classList.remove("opacity-0");
    document.body.style.overflow = "hidden";

    // Forzamos el estado visual del nav al abrir
    nav?.classList.add("bg-surface-dark/95", "backdrop-blur-md");

    document.querySelectorAll(".mobile-link").forEach((el, i) => {
      setTimeout(() => {
        (el as HTMLElement).style.opacity = "1";
        (el as HTMLElement).style.transform = "translateY(0)";
      }, 100 * i);
    });
  });

  // --- FUNCIÓN CERRAR ---
  const closeMenu = () => {
    menu?.classList.add("translate-x-full");
    mobileFooter?.classList.add("opacity-0");
    document.body.style.overflow = "auto";

    document.querySelectorAll(".mobile-link").forEach((el) => {
      (el as HTMLElement).style.opacity = "0";
      (el as HTMLElement).style.transform = "translateY(20px)";
    });

    if (window.scrollY <= 40) {
      nav?.classList.remove("bg-surface-dark/95", "backdrop-blur-md");
      // Al cerrar en el top, solo el desktop recupera el topBar
      if (isDesktop()) {
        topBar?.classList.remove("hidden");
      }
    }
  };

  closeBtn?.addEventListener("click", closeMenu);

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Limpieza al redimensionar la pantalla (por si pasan de móvil a desktop con el menú abierto)
  window.addEventListener("resize", () => {
    if (isDesktop() && window.scrollY <= 40) {
      topBar?.classList.remove("hidden");
    } else if (!isDesktop()) {
      topBar?.classList.add("hidden");
    }
  });
</script>

<style>
  .mobile-link {
    transform: translateY(20px);
    transition: all 0.5s ease;
  }
</style>
