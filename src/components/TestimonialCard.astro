---
import Star from "@/icons/Star.astro";

const { index, item } = Astro.props;
---

<div class={`break-inside-avoid group reveal delay-${((index % 3) + 1) * 100}`}>
  <div
    class="relative p-2 transition-transform duration-500 group-hover:-rotate-1"
  >
    <div
      class="flex gap-1.5 mb-6 opacity-40 group-hover:opacity-100 transition-opacity duration-500"
    >
      {[...Array(item.estrellas)].map(() => <Star />)}
    </div>

    <blockquote class="relative">
      <p
        class="text-balance text-2xl md:text-3xl font-title font-medium text-ink-primary leading-snug italic tracking-tight"
      >
        "{item.texto}"
      </p>

      <div
        class="w-0 group-hover:w-12 h-0.5 bg-brands-primary mt-8 transition-all duration-700 ease-in-out"
      >
      </div>
    </blockquote>
  </div>
</div>
