---
import { Image } from "astro:assets";

const { item, index } = Astro.props;
---

<div
  class={`group relative reveal`}
  style={`transition-delay: ${index * 100}ms`}
>
  <div
    class="group relative aspect-3/4 w-full rounded-3xl overflow-hidden shadow-2xl bg-ink-primary"
  >
    <Image
      src={item.imagen}
      alt={item.nombre}
      width={400}
      height={533}
      loading="lazy"
      class="absolute inset-0 w-full h-full object-cover transition-all duration-1000 lg:group-hover:scale-110 opacity-70 lg:opacity-80 lg:group-hover:opacity-60"
    />

    <div
      class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-transparent z-10"
    >
    </div>

    <div
      class="absolute top-0 left-0 w-full p-6 z-20 flex justify-between items-start"
    >
      <span
        class="bg-brands-primary text-black text-[10px] font-bold uppercase px-4 py-1.5 rounded-full tracking-widest shadow-xl"
      >
        {item.cat}
      </span>
      <div class="flex flex-col items-end">
        <span
          class="text-white font-title font-bold text-2xl italic drop-shadow-md"
        >
          S/ {item.precio}
        </span>
        <div class="w-8 h-0.5 bg-brands-primary mt-1"></div>
      </div>
    </div>

    <div
      class="absolute bottom-0 left-0 w-full p-6 md:p-8 z-20 flex flex-col justify-end min-h-[60%] lg:min-h-[50%]"
    >
      <h3
        class="text-3xl lg:text-4xl font-title font-bold text-white mb-2 italic leading-tight transition-transform duration-500 lg:group-hover:-translate-y-2"
      >
        {item.nombre}
      </h3>

      <div
        class="max-h-60 opacity-100 lg:max-h-0 lg:opacity-0 overflow-hidden transition-all duration-500 ease-in-out lg:group-hover:max-h-40 lg:group-hover:opacity-100"
      >
        <p
          class="text-gray-300 text-sm mb-6 italic leading-relaxed line-clamp-3 lg:line-clamp-none"
        >
          {item.desc}
        </p>
        <a
          href="/carta"
          class="inline-block w-full text-center py-4 lg:py-3 bg-brands-primary text-black font-bold uppercase text-[10px] tracking-[0.2em] rounded-lg active:scale-95 transition-transform shadow-lg"
        >
          Pedir ahora
        </a>
      </div>
    </div>
  </div>

  <div
    class="hidden lg:block absolute -bottom-4 left-1/2 -translate-x-1/2 w-[80%] h-10 bg-black/20 blur-2xl -z-10 group-hover:opacity-0 transition-opacity"
  >
  </div>
</div>
