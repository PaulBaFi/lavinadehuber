---
import { reseñas } from "@/lib/data";
---

<section class="py-32 bg-white relative overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none select-none overflow-hidden opacity-[0.03]"
  >
    <p class="text-[30rem] font-title absolute -top-40 -left-20 italic">“</p>
    <p class="text-[30rem] font-title absolute -bottom-40 -right-20 italic">
      ”
    </p>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-3xl mb-24">
      <span
        class="text-brands-primary font-bold tracking-[0.5em] uppercase text-[10px] mb-4 block"
      >
        Testimonios
      </span>
      <h2
        class="text-4xl md:text-6xl font-title font-bold text-ink-primary leading-none"
      >
        Sensaciones
        <span class="text-brands-primary italic">reales.</span>
      </h2>
    </div>

    <div class="columns-1 md:columns-2 lg:columns-3 gap-6 md:gap-12 space-y-6 md:space-y-12">
      {
        reseñas.map((r) => (
          <div class="break-inside-avoid group">
            <div class="relative p-2 transition-transform duration-500 group-hover:-rotate-1">
              <div class="flex gap-1.5 mb-6 opacity-40 group-hover:opacity-100 transition-opacity duration-500">
                {[...Array(r.estrellas)].map(() => (
                  <div class="w-1.5 h-1.5 rounded-full bg-brands-primary shadow-[0_0_8px_rgba(var(--color-primary),0.8)]" />
                ))}
              </div>

              <blockquote class="relative">
                <p class="text-2xl md:text-3xl font-title font-medium text-ink-primary leading-snug italic tracking-tight">
                  "{r.texto}"
                </p>

                <div class="w-0 group-hover:w-12 h-0.5 bg-brands-primary mt-8 transition-all duration-700 ease-in-out" />
              </blockquote>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .text-stroke-white {
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.3);
    color: transparent;
  }
  .group:hover .text-stroke-white {
    color: var(--color-brands-primary);
    -webkit-text-stroke: 0px;
  }

  blockquote p {
    text-wrap: balance;
  }
</style>
