---
import Testimonials from "@/components/Testimonials.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { todosLosPlatos, videoInicio } from "@/lib/data";
import { Image } from "astro:assets";

const specialties = todosLosPlatos.slice(0, 6)
---

<BaseLayout
  title="Inicio"
  desc="Somos un restaurante ubicado en la provincia de Pisco, expertos en la sazón marina y parrillas."
>
  <header class="relative w-full h-auto py-24 md:py-0 md:h-[90dvh] overflow-hidden flex items-center">
    <video
      class="absolute inset-0 w-full h-full object-cover z-0"
      src={videoInicio}
      muted
      loop
      autoplay
      playsinline></video>

    <div
      class="absolute inset-0 bg-linear-to-r from-black/90 via-black/60 to-transparent z-10"
    >
    </div>

    <div class="container mx-auto relative z-20 px-6">
      <div class="max-w-4xl">
        <div class="flex items-center gap-4 mb-6 animate-fade-in">
          <div class="w-6 md:w-12 h-[2px] bg-brands-primary"></div>
          <span
            class="text-brands-primary font-bold tracking-[0.3em] uppercase text-xs md:text-sm"
          >
            Sazón Marina & Parrillas
          </span>
        </div>

        <h1
          class="text-white text-6xl md:text-7xl font-bold font-title leading-[0.9] drop-shadow-2xl"
        >
          La viña de Húber:
          <span class="text-brands-primary italic font-light"
            >tradición pisqueña.</span
          >
        </h1>

        <p
          class="text-gray-300 mt-8 text-lg md:text-xl max-w-xl font-body leading-relaxed opacity-90"
        >
          Descubre la esencia de Pisco en cada bocado. Más de cuatro décadas
          perfeccionando el arte del mar y la brasa.
        </p>

        <div class="flex flex-wrap gap-6 mt-12">
          <a
            href="#carta"
            class="relative group overflow-hidden bg-brands-primary text-black px-10 py-5 rounded-xl font-bold text-lg shadow-[0_20px_40px_rgba(var(--color-primary-rgb),0.3)] transition-all duration-400 hover:-translate-y-1 hover:shadow-[0_25px_50px_rgba(var(--color-primary-rgb),0.4)]"
          >
            <span class="relative z-10 flex items-center gap-2">
              Ver Carta Digital
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 group-hover:translate-x-1 transition-transform"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
              </svg>
            </span>
            <div
              class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"
            >
            </div>
          </a>

          <a
            href="https://wa.me/51999999999"
            target="_blank"
            class="group flex items-center gap-3 px-8 py-5 rounded-xl font-bold text-lg text-white border-2 border-white/20 hover:border-brands-primary hover:text-brands-primary transition-all duration-300 backdrop-blur-sm"
          >
            <span>Reservar Mesa</span>
            <div
              class="w-2 h-2 rounded-full bg-brands-primary group-hover:scale-150 transition-transform"
            >
            </div>
          </a>
        </div>
      </div>
    </div>

    <div
      class="hidden md:block absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce opacity-50"
    >
      <div class="w-px h-12 bg-linear-to-b from-white to-transparent"></div>
    </div>
  </header>

  <section class="py-32 bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row items-center gap-16">
        <div class="lg:w-1/2 relative">
          <div
            class="absolute -top-10 -left-10 w-64 h-64 bg-brands-primary/10 rounded-full blur-3xl"
          >
          </div>
          <img
            src="/assets/images/historia-antes.png"
            alt="Historia La Viña"
            class="relative z-10 rounded-2xl shadow-2xl w-full h-[500px] object-cover"
          />
          <div
            class="absolute -bottom-8 -right-8 bg-surface-dark p-8 rounded-2xl shadow-xl z-20 hidden md:block"
          >
            <p class="text-brands-primary text-5xl font-title font-bold italic">
              40+
            </p>
            <p class="text-white uppercase tracking-widest text-xs mt-2">
              Años de Tradición
            </p>
          </div>
        </div>
        <div class="lg:w-1/2">
          <span
            class="text-brands-primary font-bold tracking-[0.3em] uppercase text-xs mb-4 block"
            >Nuestra Herencia</span
          >
          <h2
            class="text-5xl font-title font-bold text-ink-primary mb-8 italic"
          >
            Donde el fuego <br /> encuentra al mar.
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-6">
            Nacimos en el corazón de Pisco con una misión clara: honrar los
            ingredientes de nuestra tierra. Cada plato es un tributo a la
            paciencia de las brasas y la frescura del Pacífico.
          </p>
          <p class="text-ink-muted text-lg leading-relaxed italic">
            "No solo servimos comida, compartimos la historia de nuestra familia
            en cada mesa."
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-32 bg-surface-accent relative">
    <div class="container mx-auto px-4">
      <div
        class="flex flex-col md:flex-row justify-between items-end mb-20 gap-6"
      >
        <div>
          <h2
            class="text-5xl md:text-6xl font-bold text-ink-primary font-title italic"
          >
            Especiales de <span class="text-brands-primary italic">la casa</span>
          </h2>
          <p class="text-ink-muted mt-4 max-w-xl text-lg">
            Selección exclusiva de nuestras preparaciones más icónicas.
          </p>
        </div>
        <a
          href="/carta"
          class="group flex items-center gap-3 text-ink-primary font-bold uppercase tracking-widest text-sm border-b-2 border-brands-primary pb-2 hover:border-ink-primary transition-all"
        >
          Explorar toda la carta
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 group-hover:translate-x-2 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        {
          specialties.map((item) => (
            <div class="group relative">
              <div class="group relative aspect-3/4 w-full rounded-3xl overflow-hidden shadow-2xl bg-ink-primary">
                <Image
                  src={item.imagen}
                  alt={item.nombre}
				  width={300}
				  height={400}
				  loading="eager"
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 opacity-80 group-hover:opacity-60"
                />

                <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent z-10" />

                <div class="absolute top-0 left-0 w-full p-6 z-20 flex justify-between items-start">
                  <span class="bg-brands-primary text-black text-[10px] font-bold uppercase px-4 py-1.5 rounded-full tracking-widest shadow-xl">
                    {item.cat}
                  </span>
                  <div class="flex flex-col items-end">
                    <span class="text-white font-title font-bold text-2xl italic drop-shadow-md">
                      {item.precio}
                    </span>
                    <div class="w-8 h-0.5 bg-brands-primary mt-1" />
                  </div>
                </div>

                <div class="absolute bottom-0 left-0 w-full p-8 z-20 flex flex-col justify-end min-h-[50%]">
                  <h3 class="text-3xl lg:text-4xl font-title font-bold text-white mb-2 italic leading-tight transition-transform duration-500 group-hover:-translate-y-2">
                    {item.nombre}
                  </h3>

                  <div class="max-h-0 opacity-0 overflow-hidden transition-all duration-500 ease-in-out group-hover:max-h-40 group-hover:opacity-100">
                    <p class="text-gray-300 text-sm mb-6 italic leading-relaxed">
                      {item.desc}
                    </p>
                    <a
                      href="/carta"
                      class="inline-block w-full text-center py-3 bg-brands-primary text-black font-bold uppercase text-[10px] tracking-[0.2em] rounded-lg active:scale-95 transition-transform"
                    >
                      Pedir ahora
                    </a>
                  </div>
                </div>
              </div>

              <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-[80%] h-10 bg-black/20 blur-2xl -z-10 group-hover:opacity-0 transition-opacity" />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Testimonials />

  <section class="py-16 bg-surface-dark overflow-hidden relative">
    <div
      class="absolute inset-0 opacity-15 bg-[url('/assets/images/pattern-grill.png')] bg-repeat bg-size-[600px] blur-[2px]"
    >
    </div>

    <div
      class="absolute inset-0 bg-radial-[at_center] from-transparent via-surface-dark/60 to-surface-dark"
    >
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center">
      <div class="w-12 h-px bg-brands-primary/50 mx-auto mb-8"></div>

      <h2
        class="text-white text-3xl md:text-3xl lg:text-4xl font-title font-light italic max-w-5xl mx-auto drop-shadow-2xl"
      >
        "El secreto no está solo en la receta, <br class="hidden md:block" />
        sino en el <span class="text-brands-primary font-bold not-italic"
          >respeto por el producto."</span
        >
      </h2>

      <div class="w-12 h-px bg-brands-primary/50 mx-auto mt-8"></div>
    </div>
  </section>
</BaseLayout>

<style>
  :root {
    --color-primary-rgb: 255, 191, 0;
  }

  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
