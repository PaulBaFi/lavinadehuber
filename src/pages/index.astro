---
import Testimonials from "@/components/Testimonials.astro";
import Specialties from "@/components/Specialties.astro";
import BigArrowRight from "@/icons/BigArrowRight.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { videoInicio } from "@/lib/data";
import { Image } from "astro:assets";

import { contacto, horario } from "@/lib/data";
import Phone from "@/icons/Phone.astro";
import ReservarForm from "@/components/ReservarForm.astro";
---

<BaseLayout
  title="Inicio"
  desc="Somos un restaurante ubicado en la provincia de Pisco, expertos en la sazón marina y parrillas."
>
  <header
    class="relative w-full h-auto py-24 md:py-0 md:h-[90dvh] overflow-hidden flex items-center"
  >
    <div
      class="absolute inset-0 z-0"
      style="clip-path: ellipse(140% 100% at 50% 0%);"
    >
      <video
        class="absolute inset-0 w-full h-full object-cover z-0"
        src={videoInicio}
        muted
        loop
        autoplay
        playsinline></video>

      <div
        class="absolute inset-0 bg-linear-to-r from-black/90 via-black/60 to-transparent z-10"
      >
      </div>
    </div>

    <div class="container mx-auto relative z-20 px-4 md:px-6">
      <div class="max-w-4xl">
        <div class="flex items-center gap-3 mb-4 md:mb-6 animate-fade-in">
          <div class="w-8 md:w-12 h-[2px] bg-brands-primary"></div>
          <span
            class="text-brands-primary font-bold tracking-[0.2em] md:tracking-[0.3em] uppercase text-[10px] md:text-sm"
          >
            Sazón Marina & Parrillas
          </span>
        </div>

        <h1
          class="animate-fade-in custom-delay-200 text-white text-4xl md:text-6xl lg:text-7xl font-bold font-title leading-[1.1] md:leading-[0.9] drop-shadow-2xl"
        >
          La viña de Húber:
          <span class="text-brands-primary italic font-light block md:inline"
            >tradición pisqueña.</span
          >
        </h1>

        <p
          class="animate-fade-in custom-delay-300 text-gray-300 mt-6 md:mt-8 text-base md:text-xl max-w-xl font-body leading-relaxed opacity-90"
        >
          Descubre la esencia de Pisco en cada bocado. Más de cuatro décadas
          perfeccionando el arte del mar y la brasa.
        </p>

        <div
          class="animate-fade-in custom-delay-500 flex flex-col sm:flex-row gap-4 md:gap-6 mt-10 md:mt-12"
        >
          <a
            href="/carta"
            class="relative group overflow-hidden bg-brands-primary text-black px-8 py-4 md:px-10 md:py-5 rounded-xl font-bold text-base md:text-lg shadow-[0_20px_40px_rgba(var(--color-primary-rgb),0.3)] transition-all duration-400 hover:-translate-y-1 text-center"
          >
            <span class="relative z-10 flex items-center justify-center gap-2">
              Ver Carta
              <BigArrowRight size="18" />
            </span>
            <div
              class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"
            >
            </div>
          </a>

          <a
            href="/reservar"
            class="group relative overflow-hidden flex items-center justify-center gap-3 px-8 py-4 md:py-5 rounded-xl font-medium text-base md:text-lg text-white border-2 border-white/20 hover:border-brands-primary hover:text-brands-primary transition-all duration-300 backdrop-blur-sm"
          >
            <span>Reservar Mesa</span>
            <div
              class="absolute -inset-full h-full w-1/2 z-5 block transform -skew-x-12 bg-linear-to-r from-transparent via-white/10 to-transparent group-hover:animate-[shine_0.75s] opacity-0 group-hover:opacity-100"
            >
            </div>
          </a>
        </div>
      </div>
    </div>

    <div
      class="hidden md:block absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce opacity-50"
    >
      <div class="w-px h-12 bg-linear-to-b from-white to-transparent"></div>
    </div>
  </header>

  <section class="py-18 md:py-32 bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div
        class="flex flex-col-reverse lg:flex-row items-center gap-8 md:gap-16"
      >
        <div class="lg:w-1/2 relative reveal">
          <div
            class="absolute -top-10 -left-10 w-64 h-64 bg-brands-primary/10 rounded-full blur-3xl"
          >
          </div>
          <Image
            src="/assets/images/historia-antes.png"
            alt="Historia La Viña"
            width={250}
            height={250}
            loading="lazy"
            class="relative z-10 rounded-2xl shadow-2xl w-full h-[500px] object-cover"
          />
          <div
            class="absolute -bottom-8 -right-8 bg-surface-dark p-8 rounded-2xl shadow-xl z-20 hidden md:block"
          >
            <p class="text-brands-primary text-5xl font-title font-bold italic">
              40+
            </p>
            <p class="text-white uppercase tracking-widest text-xs mt-2">
              Años de Tradición
            </p>
          </div>
        </div>
        <div class="lg:w-1/2 reveal delay-200">
          <span
            class="text-brands-primary font-bold tracking-[0.3em] uppercase text-xs mb-4 block"
            >Nuestra Herencia</span
          >
          <h2
            class="text-5xl font-title font-bold text-ink-primary mb-8 italic"
          >
            Donde el fuego <br /> encuentra al mar.
          </h2>
          <p class="text-ink-muted text-lg leading-relaxed mb-6">
            Nacimos en el corazón de Pisco con una misión clara: honrar los
            ingredientes de nuestra tierra. Cada plato es un tributo a la
            paciencia de las brasas y la frescura del Pacífico.
          </p>
          <p class="text-ink-muted text-lg leading-relaxed italic">
            "No solo servimos comida, compartimos la historia de nuestra familia
            en cada mesa."
          </p>
        </div>
      </div>
    </div>
  </section>

  <Specialties />

  <section class="relative z-20 py-18 md:py-32 bg-surface-accent/50">
    <div class="container mx-auto px-4">
      <div
        class="rounded-2xl mx-auto bg-white shadow-[0_40px_100px_-20px_rgba(0,0,0,0.1)] border border-b-base flex flex-col-reverse lg:flex-row overflow-hidden"
      >
        <aside
          class="lg:w-1/3 bg-ink-primary p-10 md:p-16 text-white flex flex-col justify-between border-b lg:border-b-0 lg:border-r border-white/5"
        >
          <div>
            <h4 class="font-title text-3xl italic text-brands-primary mb-8">
              Información
            </h4>

            <div class="space-y-10">
              <div class="space-y-4">
                <p
                  class="text-[10px] uppercase tracking-[0.3em] text-white/40 font-bold"
                >
                  Horarios
                </p>
                <div class="space-y-2">
                  {
                    horario.map((item) => (
                      <div class="flex justify-between text-xs font-body border-b border-white/5 pb-2">
                        <span class="text-white/60">{item.dia}</span>
                        <span
                          class={
                            item.hora_cierre
                              ? "text-white"
                              : "text-brands-primary italic"
                          }
                        >
                          {item.hora_cierre
                            ? `${item.hora_apertura} - ${item.hora_cierre}`
                            : "Cerrado"}
                        </span>
                      </div>
                    ))
                  }
                </div>
              </div>

              <div class="space-y-4">
                <p
                  class="text-[10px] uppercase tracking-[0.3em] text-white/40 font-bold"
                >
                  Ubicación
                </p>
                <p
                  class="text-sm font-body leading-relaxed text-white/80 italic"
                >
                  {contacto.address}<br />
                  Pisco, Perú.
                </p>
              </div>
            </div>
          </div>

          <div class="mt-12 pt-10 border-t border-white/5">
            <a
              href={`tel:${contacto.phone}`}
              class="group flex items-center gap-4"
            >
              <div
                class="w-12 h-12 rounded-full border border-brands-primary/30 flex items-center justify-center group-hover:bg-brands-primary transition-all duration-500"
              >
                <Phone
                  class="w-5 h-5 text-brands-primary group-hover:text-black transition-colors"
                />
              </div>
              <div>
                <p
                  class="text-[9px] uppercase tracking-widest text-white/40 font-bold"
                >
                  Reservas Teléfono
                </p>
                <p
                  class="text-lg font-title text-white font-bold tracking-tighter"
                >
                  {contacto.phone}
                </p>
              </div>
            </a>
          </div>
        </aside>

        <div class="lg:w-2/3 px-6 py-10 md:p-16 bg-white">
          <div class="mb-12">
            <h2
              class="font-title text-4xl text-ink-primary italic font-bold mb-2"
            >
              Solicitar Reserva
            </h2>
            <p class="text-ink-muted text-sm font-body italic">
              Complete el formulario y confirmaremos su mesa vía WhatsApp.
            </p>
          </div>

          <ReservarForm />
        </div>
      </div>
    </div>
  </section>

  <Testimonials />

  <section class="py-16 bg-surface-dark overflow-hidden relative">
    <div
      class="absolute inset-0 opacity-15 bg-[url('/assets/images/pattern-grill.png')] bg-repeat bg-size-[600px] blur-[2px]"
    >
    </div>

    <div
      class="absolute inset-0 bg-radial-[at_center] from-transparent via-surface-dark/60 to-surface-dark"
    >
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center">
      <div class="w-12 h-px bg-brands-primary/50 mx-auto mb-8"></div>

      <h2
        class="text-white text-3xl md:text-3xl lg:text-4xl font-title font-light italic max-w-5xl mx-auto drop-shadow-2xl"
      >
        "El secreto no está solo en la receta, <br class="hidden md:block" />
        sino en el <span class="text-brands-primary font-bold not-italic"
          >respeto por el producto."</span
        >
      </h2>

      <div class="w-12 h-px bg-brands-primary/50 mx-auto mt-8"></div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes shine {
    100% {
      left: 125%;
    }
  }
</style>

<script>
  const observerOptions = {
    threshold: 0.1,
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("active");
      }
    });
  }, observerOptions);

  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>
