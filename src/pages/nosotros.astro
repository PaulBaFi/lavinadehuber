---
import {
  imagenHistoriaUno,
  imagenHistoriaDos,
  equipo,
  imageNosotros,
} from "@/lib/data";
import { Image } from "astro:assets";
import Testimonials from "@/components/Testimonials.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Nosotros"
  desc="Conoce la historia y el equipo detrás de La Viña de Huber."
>
  <header class="relative h-[40vh] min-h-[500px] overflow-hidden">
    <div class="absolute inset-0 z-0" style="clip-path: inset(0 0 0 0);">
      <div
        class="fixed inset-0 w-full h-full bg-cover bg-center bg-no-repeat pointer-events-none"
        style={`background-image: url('${imageNosotros}'); z-index: -1;`}
      >
        <div
          class="absolute inset-0 bg-black/50 bg-linear-to-b from-black/60 to-black/20"
        >
        </div>
      </div>
    </div>

    <div class="relative z-10 h-full flex items-center justify-center">
      <div class="container mx-auto px-4 text-center">
        <span
          class="text-brands-primary font-bold tracking-[0.4em] uppercase text-xs mb-4 block animate-fade-in"
        >
          Nuestra Herencia
        </span>
        <h1
          class="animate-fade-in text-6xl md:text-7xl font-bold font-title text-white mb-8 italic drop-shadow-2xl"
        >
          Más que un sabor,<br />
          <span class="text-brands-primary">una historia.</span>
        </h1>
        <div
          class="animate-fade-in w-24 h-1 bg-brands-primary mx-auto rounded-full"
        >
        </div>
      </div>
    </div>
  </header>

  <section class="py-12 md:py-24 bg-white relative z-10">
    <div class="container mx-auto px-4">
      <div
        class="max-w-4xl mx-auto space-y-6 md:space-y-12 font-body text-lg leading-relaxed text-ink-muted"
      >
        <p
          class="first-letter:text-7xl first-letter:font-title first-letter:font-bold first-letter:text-brands-primary first-letter:mr-3 first-letter:float-left"
        >
          La historia de <strong class="text-ink-primary"
            >La Viña de Huber</strong
          > nace en la ciudad de Pisco en el año 1986. Sus fundadores: Huber Martínez
          Mayaute y su esposa Micaela Barrientos de Martínez, iniciaron como un pequeño
          Bar vendiendo licores de Ica (piscos y vinos) de ahí el nombre de nuestro
          restaurante “La Viña” por los licores de Ica y Huber por el nombre de uno
          de nuestros fundadores Don Huber.
        </p>

        <p>
          Más adelante, nuestra fundadora Doña Micaela, quiso compartir su arte
          culinario elaborando exquisitos platos con insumos de nuestra
          provincia logrando gran aceptación entre los comensales que día a día
          fueron creciendo gracias a la excelente cocina de Doña Mica como
          cariñosamente le llamamos.
        </p>

        <p>
          Nuestros platos son preparados al momento utilizando siempre productos
          frescos cuidando cada detalle de la presentación con el fin de
          mantener la calidad que siempre nos ha caracterizado.
        </p>

        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8 py-4 md:py-8"
        >
          <div
            class="aspect-square bg-surface-accent rounded-3xl overflow-hidden shadow-2xl group"
          >
            <Image
              src={imagenHistoriaUno}
              alt="Local antiguo"
              width={400}
              height={400}
              loading="lazy"
              class="w-full h-full object-cover md:grayscale md:group-hover:grayscale-0 group-hover:scale-110 transition-all duration-700"
            />
          </div>
          <div
            class="aspect-3/4 bg-surface-dark rounded-3xl overflow-hidden shadow-2xl md:mt-12 group"
          >
            <Image
              src={imagenHistoriaDos}
              alt="Chef cocinando"
              width={300}
              height={400}
              loading="lazy"
              class="w-full h-full object-cover md:grayscale md:group-hover:grayscale-0 group-hover:scale-110 transition-all duration-700"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-24 bg-surface-dark text-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div
        class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6"
      >
        <div class="max-w-2xl">
          <span
            class="text-brands-primary font-bold tracking-[0.3em] uppercase text-xs mb-4 block"
          >
            NUESTRO EQUIPO
          </span>
          <h2
            class="text-5xl md:text-7xl font-title font-bold italic leading-tight"
          >
            Nuestra <span class="text-brands-primary">Familia</span>
          </h2>
        </div>
        <div class="hidden md:block w-32 h-px bg-white/20 mb-4"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          equipo.map((persona) => (
            <div class="group relative">
              <div class="relative aspect-4/5 overflow-hidden rounded-2xl border border-white/10 bg-white/5 transition-all duration-700 lg:group-hover:border-brands-primary/50 lg:group-hover:-translate-y-2">
                <div class="absolute inset-0 bg-linear-to-t from-surface-dark via-surface-dark/40 to-transparent opacity-90 lg:opacity-80 z-10" />

                <Image
                  src={persona.image}
                  alt={persona.nombre}
                  width={400}
                  height={500}
                  loading="lazy"
                  class="w-full h-full object-cover grayscale-0 lg:md:grayscale lg:group-hover:grayscale-0 lg:group-hover:scale-110 transition-all duration-1000"
                />

                <div class="absolute bottom-0 left-0 w-full p-6 md:p-8 z-20 translate-y-0 lg:translate-y-4 lg:group-hover:translate-y-0 transition-transform duration-500">
                  <p class="text-brands-primary text-[10px] uppercase tracking-[0.2em] font-bold mb-2 opacity-100 lg:opacity-0 lg:group-hover:opacity-100 transition-opacity delay-100">
                    {persona.rol}
                  </p>

                  <h3 class="text-2xl md:text-3xl font-title font-bold italic mb-2">
                    {persona.nombre}
                  </h3>

                  <p class="text-gray-300 md:text-gray-400 text-sm leading-relaxed line-clamp-3 md:line-clamp-2 opacity-100 lg:opacity-0 lg:group-hover:opacity-100 transition-opacity delay-200">
                    {persona.desc}
                  </p>
                </div>
              </div>

              <div class="hidden lg:block absolute -inset-2 bg-brands-primary/5 blur-2xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity -z-10" />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Testimonials />
</BaseLayout>

<style>
  @supports (-webkit-overflow-scrolling: touch) {
    .bg-fixed {
      background-attachment: scroll;
    }
  }
</style>
