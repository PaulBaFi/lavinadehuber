---
import BaseHead from "@/components/BaseHead.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import "../styles/global.css";
import { contacto } from "@/lib/data";
import BigArrowRight from "@/icons/BigArrowRight.astro";

// Limpiamos el número por si tiene espacios
const wspNumber = contacto.phone.replace(/\s+/g, "");

interface Props {
  title: string;
  desc: string;
}

const { title, desc } = Astro.props;
---

<html lang="es">
  <head>
    <BaseHead />
    <title>{title}</title>
    <meta name="description" content={desc} />
  </head>

  <body
    class="bg-surface-light selection:bg-brands-primary selection:text-black"
  >
    <Navbar />
    <slot />
    <Footer />

    <div id="cart-panel" class="fixed inset-0 z-100 invisible">
      <div
        id="cart-overlay"
        class="absolute inset-0 bg-ink-primary/80 backdrop-blur-md opacity-0 transition-opacity duration-500 cursor-crosshair"
      >
      </div>

      <div
        id="cart-content"
        class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-[0_0_50px_rgba(0,0,0,0.3)] translate-x-full transition-transform ease-in-out duration-500 flex flex-col border-l border-white/10"
      >
        <div
          class="p-8 border-b border-b-base flex justify-between items-center bg-surface-accent/50"
        >
          <div>
            <h3
              class="font-title text-3xl text-ink-primary italic font-bold leading-tight"
            >
              Tu Selección
            </h3>
            <div class="flex items-center gap-2">
              <span class="w-8 h-px bg-brands-primary"></span>
              <p
                class="text-brands-primary text-[10px] uppercase tracking-[0.4em] font-bold"
              >
                La Viña de Huber
              </p>
            </div>
          </div>
          <button id="cart-close" class="group p-2">
            <svg
              class="text-ink-muted group-hover:text-brands-primary group-hover:rotate-90 transition-all duration-300"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M18 6L6 18M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <div
          id="cart-items"
          class="flex-1 overflow-y-auto p-4 md:p-8 space-y-4 md:space-y-6 bg-white custom-scrollbar"
        >
        </div>

        <div
          class="p-4 md:p-8 bg-surface-accent border-t border-b-base space-y-4 md:space-y-6 shadow-lg"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
            <div class="relative group">
              <input
                type="text"
                id="cust-name"
                required
                class="peer w-full bg-surface-accent border-b border-b-base py-3 text-ink-primary outline-none focus:border-brands-primary px-4 transition-all font-body placeholder-transparent"
                placeholder="¿A nombre de quién?"
              />
              <label
                class="absolute left-4 -top-3.5 text-ink-muted text-[10px] uppercase tracking-widest font-bold transition-all peer-placeholder-shown:text-base peer-placeholder-shown:top-3 peer-focus:left-0 peer-focus:-top-3.5 peer-focus:text-[10px] peer-focus:text-brands-primary pointer-events-none"
                >¿A nombre de quién?</label
              >
            </div>

            <div class="relative group">
              <input
                type="text"
                id="cust-address"
                required
                class="peer w-full bg-surface-accent border-b border-b-base py-3 text-ink-primary outline-none focus:border-brands-primary px-4 transition-all font-body placeholder-transparent"
                placeholder="Dirección exacta en Pisco"
              />
              <label
                class="absolute left-4 -top-3.5 text-ink-muted text-[10px] uppercase tracking-widest font-bold transition-all peer-placeholder-shown:text-base peer-placeholder-shown:top-3 peer-focus:left-0 peer-focus:-top-3.5 peer-focus:text-[10px] peer-focus:text-brands-primary pointer-events-none"
                >Dirección de envío</label
              >
            </div>
          </div>

          <div class="pt-2 md:pt-4">
            <div class="flex justify-between items-center mb-4 md:mb-6">
              <span
                class="font-body text-[10px] uppercase tracking-widest text-ink-muted"
                >Total</span
              >
              <span
                id="cart-total"
                class="font-title font-bold text-ink-primary text-3xl md:text-4xl"
                >S/ 0.00</span
              >
            </div>

            <button
              id="whatsapp-confirm"
              class="w-full bg-ink-primary text-brands-primary font-bold py-4 md:py-6 rounded-none uppercase text-[10px] md:text-[11px] tracking-[0.3em] flex items-center justify-center gap-2 group"
            >
              Confirmar Orden
              <BigArrowRight size="18" />
            </button>
            <p
              class="text-[9px] text-center text-ink-muted italic mt-4 uppercase tracking-widest opacity-60"
            >
              Se abrirá WhatsApp para finalizar la compra
            </p>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>

<style is:global>
  .custom-scrollbar::-webkit-scrollbar {
    width: 3px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #d4af37;
  }

  @keyframes pulse-gold {
    0% {
      transform: scale(0.6);
      opacity: 0.9;
    }
    100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }

  .is-pulsing {
    display: block !important;
    animation: pulse-gold 1.5s infinite cubic-bezier(0.4, 0, 0.6, 1) !important;
    visibility: visible !important;
  }
</style>

<script is:inline define:vars={{ wspNumber }}>
  window.toggleCart = (forceOpen = true) => {
    const panel = document.getElementById("cart-panel");
    const content = document.getElementById("cart-content");
    const overlay = document.getElementById("cart-overlay");

    if (forceOpen) {
      panel.classList.remove("invisible");
      document.body.style.overflow = "hidden";
      setTimeout(() => {
        overlay.classList.add("opacity-100");
        content.classList.remove("translate-x-full");
      }, 50);
    } else {
      overlay.classList.remove("opacity-100");
      content.classList.add("translate-x-full");
      setTimeout(() => {
        panel.classList.add("invisible");
        document.body.style.overflow = "auto";
      }, 500);
    }
  };

  document.addEventListener("DOMContentLoaded", () => {
    let rawCart = JSON.parse(localStorage.getItem("hubers_cart")) || [];

    // CORRECCIÓN: Asegura que los productos viejos tengan cantidad 1 si no la tienen
    let cart = rawCart.map((item) => ({
      ...item,
      cantidad: item.cantidad || 1,
    }));

    const cartItemsContainer = document.getElementById("cart-items");
    const cartTotal = document.getElementById("cart-total");

    const renderCart = () => {
      cartItemsContainer.innerHTML = "";

      if (cart.length === 0) {
        cartItemsContainer.innerHTML = `
            <div class="h-full flex flex-col items-center justify-center opacity-40 py-20">
              <svg class="mb-4" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
              <p class="italic font-body text-sm text-center">Tu bolsa está vacía.</p>
            </div>`;
      }

      let subtotal = 0;
      let totalUnits = 0;

      cart.forEach((item, index) => {
        const itemPrice = parseFloat(item.precio) || 0;
        const qty = parseInt(item.cantidad) || 1;
        subtotal += itemPrice * qty;
        totalUnits += qty;

        cartItemsContainer.innerHTML += `
            <div class="flex items-center gap-3 md:gap-5 group border-b border-b-base pb-4">
              <div class="relative overflow-hidden w-14 h-14 md:w-20 md:h-20 shadow-sm shrink-0 rounded-lg">
                  <img src="${item.imagen}" class="w-full h-full object-cover">
              </div>
              <div class="flex-1 min-w-0">
                <h4 class="text-ink-primary text-[10px] md:text-[11px] font-bold uppercase tracking-wide mb-1 truncate">${item.nombre}</h4>
                <div class="flex items-center justify-between">
                  <p class="text-brands-primary text-lg md:text-xl font-title italic">S/ ${item.precio}</p>
                  
                  <div class="flex items-center border border-gray-200 rounded-md bg-white overflow-hidden shadow-sm">
                    <button onclick="window.updateQty(${index}, -1)" class="px-2 py-1 hover:bg-brands-primary hover:text-white transition-colors">-</button>
                    <span class="px-3 py-1 text-xs font-bold bg-gray-50/50">${qty}</span>
                    <button onclick="window.updateQty(${index}, 1)" class="px-2 py-1 hover:bg-brands-primary hover:text-white transition-colors">+</button>
                  </div>
                </div>
              </div>
              <button onclick="window.removeFromCart(${index})" class="text-red-400/50 hover:text-red-500 transition-colors p-2 text-xl">
                &times;
              </button>
            </div>`;
      });

      cartTotal.innerText = `S/ ${subtotal.toFixed(2)}`;

      const counter = document.getElementById("cart-count");
      const pulse = document.getElementById("cart-pulse");
      if (totalUnits > 0) {
        if (counter) {
          counter.innerText = totalUnits;
          counter.style.opacity = "1";
          counter.style.transform = "scale(1)";
        }
        if (pulse) pulse.classList.add("is-pulsing");
      } else {
        if (counter) {
          counter.style.opacity = "0";
          counter.style.transform = "scale(0)";
        }
        if (pulse) pulse.classList.remove("is-pulsing");
      }
    };

    const saveCart = () => {
      localStorage.setItem("hubers_cart", JSON.stringify(cart));
      renderCart();
    };

    window.addToCart = (nombre, precio, imagen) => {
      const existing = cart.find((item) => item.nombre === nombre);
      if (existing) {
        existing.cantidad = (parseInt(existing.cantidad) || 1) + 1;
      } else {
        cart.push({ nombre, precio, imagen, cantidad: 1 });
      }
      saveCart();
      window.toggleCart(true);
    };

    window.updateQty = (index, change) => {
      const currentQty = parseInt(cart[index].cantidad) || 1;
      const newQty = currentQty + change;

      if (newQty <= 0) {
        window.removeFromCart(index);
      } else {
        cart[index].cantidad = newQty;
        saveCart();
      }
    };

    window.removeFromCart = (index) => {
      cart.splice(index, 1);
      saveCart();
    };

    // Botones de la carta
    document.addEventListener("click", (e) => {
      const btn = e.target.closest(".btn-add-order");
      if (btn) {
        const { plato, precio, imagen } = btn.dataset;
        window.addToCart(plato, precio, imagen);

        const originalText = btn.innerText;
        btn.innerText = "¡AÑADIDO!";
        btn.classList.add("bg-brands-primary", "text-black");
        setTimeout(() => {
          btn.innerText = originalText;
          btn.classList.remove("bg-brands-primary", "text-black");
        }, 1000);
      }
    });

    // Enlaces de apertura y cierre
    document
      .getElementById("cart-toggle")
      ?.addEventListener("click", () => window.toggleCart(true));
    document
      .getElementById("cart-toggle-mobile")
      ?.addEventListener("click", () => window.toggleCart(true));
    document
      .getElementById("cart-close")
      ?.addEventListener("click", () => window.toggleCart(false));
    document
      .getElementById("cart-overlay")
      ?.addEventListener("click", () => window.toggleCart(false));

    // WhatsApp Confirmación
    const wspBtn = document.getElementById("whatsapp-confirm");
    if (wspBtn) {
      wspBtn.onclick = () => {
        const name = document.getElementById("cust-name").value.trim();
        const address = document.getElementById("cust-address").value.trim();

        if (!name || !address) {
          alert("Por favor, ingresa tu nombre y dirección.");
          return;
        }
        if (cart.length === 0) return;

        const pedidoTexto = cart
          .map((i) => `• ${i.cantidad}x ${i.nombre} (S/ ${i.precio} c/u)`)
          .join("%0A");

        const msg = `*NUEVO PEDIDO - LA VIÑA*%0A%0A*Cliente:* ${name}%0A*Dirección:* ${address}%0A%0A*PRODUCTOS:*%0A${pedidoTexto}%0A%0A*TOTAL:* ${cartTotal.innerText}%0A%0A_Enviado desde el sitio web._`;

        window.open(`https://wa.me/${wspNumber}?text=${msg}`, "_blank");
        cart = [];
        saveCart();
        window.toggleCart(false);
      };
    }

    renderCart();
  });
</script>
